# Copied to .env and used by docker-compose.yml (see backend/.env.example for
# the same variables when running the backend directly during development).

ZENODO_ENV=sandbox
ZENODO_SANDBOX_CLIENT_ID=
ZENODO_SANDBOX_CLIENT_SECRET=
ZENODO_PROD_CLIENT_ID=
ZENODO_PROD_CLIENT_SECRET=
ZENODO_REDIRECT_URI=http://localhost:8000/api/auth/zenodo/callback
SESSION_SECRET=change-me-in-production

# Set when served behind a reverse-proxy subfolder, e.g. "/plop" for foobar.com/plop.
URL_BASE_PATH=

APP_PORT=8000

# Per-file cap on model file uploads (MB). Zenodo itself allows up to 50GB/file.
MAX_UPLOAD_MB=5120
