# Which Zenodo instance this deployment talks to: "sandbox" | "production"
ZENODO_ENV=sandbox

# Register an OAuth application at https://sandbox.zenodo.org/account/settings/applications/
# (and separately at https://zenodo.org/account/settings/applications/ for production)
# requesting the "deposit:write" and "deposit:actions" scopes.
ZENODO_SANDBOX_CLIENT_ID=
ZENODO_SANDBOX_CLIENT_SECRET=
ZENODO_PROD_CLIENT_ID=
ZENODO_PROD_CLIENT_SECRET=

# Must exactly match the redirect URI configured on the Zenodo OAuth application.
ZENODO_REDIRECT_URI=http://localhost:8000/api/auth/zenodo/callback

SESSION_SECRET=change-me-in-production

DATABASE_PATH=./data/htrmopo-app.db

# Per-file cap on model file uploads, enforced while streaming to local disk
# (Zenodo itself allows up to 50GB/file).
MAX_UPLOAD_MB=5120

# Set when served behind a reverse-proxy subfolder, e.g. "/plop" for foobar.com/plop.
# Leave empty when the app owns its own domain/root path.
URL_BASE_PATH=

FRONTEND_DIST_DIR=./static

# Refreshes the catalog from the public ocr_models Zenodo community once a
# day (in addition to the refresh already triggered by every publish).
ENABLE_NIGHTLY_HARVEST=true
NIGHTLY_HARVEST_HOUR_UTC=2

# Try-a-model-in-the-browser feature. Needs the separate `runner` container
# (see docker-compose.yml) to actually process jobs -- set to false in
# deployments that don't build/run it.
ENABLE_PLAYGROUND=true
PLAYGROUND_DATABASE_PATH=./data/playground.db
PLAYGROUND_RUNNER_URL=http://runner:8100
PLAYGROUND_JOB_TIMEOUT_SECONDS=300
PLAYGROUND_MAX_ROWS=100
PLAYGROUND_RATE_LIMIT_MAX_PER_IP=5
PLAYGROUND_RATE_LIMIT_WINDOW_MINUTES=60
